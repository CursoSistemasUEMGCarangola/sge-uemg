# SGE - Template de Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais

# Connect to Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Connect to Database (Prisma)
# Use "Transaction Mode" (porta 6543) com ?pgbouncer=true para Serverless
DATABASE_URL="postgresql://postgres.[REF]:[PASS]@[HOST]:6543/postgres?pgbouncer=true"

# Direct Connection for Migrations
# Use "Session Mode" (porta 5432)
DIRECT_URL="postgresql://postgres.[REF]:[PASS]@[HOST]:5432/postgres"

# Supabase Service Role (Necessária para Backups/Admin Auth)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# APIs Externas
OPENROUTER_API_KEY=your-openrouter-key
